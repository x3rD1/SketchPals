generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Canvas {
  id      String   @id @default(uuid())
  strokes Stroke[]
  version Int      @default(0)

  @@map("canvas")
}

model Stroke {
  id        String   @id
  points    Json
  createdAt DateTime @default(now())
  canvasId  String
  canvas    Canvas   @relation(fields: [canvasId], references: [id], onDelete: Cascade)

  @@map("strokes")
}
